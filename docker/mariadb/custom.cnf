# =============================================================================
# MariaDB 11 Optimized Configuration
# Target: 32GB RAM, 8-core Intel Xeon, Docker container
# Workload: ~20k+ row inserts/day into daily_snapshots, read-heavy dashboard
# =============================================================================

[mysqld]

# ---------------------------------------------------------------------------
# InnoDB Buffer Pool
# ---------------------------------------------------------------------------
# Primary memory allocation for InnoDB. Caches data and indexes in memory.
# Set to ~12GB — roughly 40% of 32GB total, leaving headroom for OS, backend,
# frontend containers, and other Docker services on the same host.
# If MariaDB is the dominant workload, this can be raised to 16-20GB.
innodb_buffer_pool_size         = 12G

# Split the buffer pool into multiple instances for reduced mutex contention.
# Rule of thumb: 1 instance per 1-2GB of buffer pool, max 64.
innodb_buffer_pool_instances    = 8

# Dump/load buffer pool state on shutdown/startup for faster warm-up.
innodb_buffer_pool_dump_at_shutdown = ON
innodb_buffer_pool_load_at_startup  = ON

# ---------------------------------------------------------------------------
# InnoDB Redo Log (Write-Ahead Log)
# ---------------------------------------------------------------------------
# Larger redo logs reduce checkpoint frequency, improving write throughput.
# 2GB is appropriate for 20k+ inserts/day with wide rows (~1-2KB each).
innodb_log_file_size            = 2G

# Log buffer — holds redo log entries before flushing to disk.
# 64MB is generous for batch insert workloads.
innodb_log_buffer_size          = 64M

# ---------------------------------------------------------------------------
# InnoDB Flush & I/O Settings
# ---------------------------------------------------------------------------
# Flush log at each commit for ACID compliance (safest).
# Change to 2 if you can tolerate up to 1 second of data loss on crash
# for significantly better write performance.
innodb_flush_log_at_trx_commit  = 1

# O_DIRECT bypasses OS file cache, preventing double-buffering since InnoDB
# has its own buffer pool. Reduces memory pressure on the host.
innodb_flush_method             = O_DIRECT

# I/O capacity — controls background flushing rate.
# 2000/4000 is appropriate for SSD storage; reduce for spinning disks.
innodb_io_capacity              = 2000
innodb_io_capacity_max          = 4000

# Number of background I/O threads for reads and writes.
# 8 each is appropriate for 8-core system with SSD.
innodb_read_io_threads          = 8
innodb_write_io_threads         = 8

# Page cleaner threads — flush dirty pages in parallel.
innodb_page_cleaners            = 4

# Purge threads — clean up old row versions (MVCC) in parallel.
innodb_purge_threads            = 4

# ---------------------------------------------------------------------------
# InnoDB Change Buffer & Doublewrite
# ---------------------------------------------------------------------------
# Change buffer for secondary index updates during inserts.
# "inserts" mode is optimal for insert-heavy workloads.
innodb_change_buffering         = inserts

# Doublewrite buffer protects against partial page writes on crash.
# Keep ON for data safety. Disable only if filesystem guarantees atomic writes.
innodb_doublewrite              = ON

# ---------------------------------------------------------------------------
# Connection & Thread Handling
# ---------------------------------------------------------------------------
# Max connections — sized for backend connection pool + admin headroom.
max_connections                 = 200

# Thread cache — avoids thread creation overhead for new connections.
thread_cache_size               = 32

# Use thread pool for better concurrency under load (MariaDB feature).
# Pool size matches CPU core count.
thread_handling                 = pool-of-threads
thread_pool_size                = 8

# Back log — queue size for pending connections during connection spikes.
back_log                        = 128

# ---------------------------------------------------------------------------
# Per-Session Memory Buffers
# ---------------------------------------------------------------------------
# These are allocated PER CONNECTION, so keep them reasonable.
# With max_connections=200, worst case: 200 * (sort+read+join) ≈ 2.4GB

# Sort buffer for ORDER BY operations on the wide daily_snapshots table.
sort_buffer_size                = 4M

# Read buffer for sequential table scans.
read_buffer_size                = 2M

# Read buffer for post-sort row reads (used after ORDER BY).
read_rnd_buffer_size            = 4M

# Join buffer for joins without indexes (should be rare with proper indexing).
join_buffer_size                = 2M

# ---------------------------------------------------------------------------
# Temporary Tables
# ---------------------------------------------------------------------------
# In-memory temp table limit before spilling to disk.
# Sized for complex dashboard aggregation queries across daily_snapshots.
tmp_table_size                  = 128M
max_heap_table_size             = 128M

# ---------------------------------------------------------------------------
# Table & Definition Cache
# ---------------------------------------------------------------------------
# Cache open table file descriptors. With 2 tables + indexes, 400 is plenty.
table_open_cache                = 400

# Cache table definitions (DDL metadata).
table_definition_cache          = 400

# Open files limit — must be >= table_open_cache.
open_files_limit                = 65535

# ---------------------------------------------------------------------------
# Query Optimization
# ---------------------------------------------------------------------------
# Optimizer switch: enable index_merge and other optimizations.
optimizer_switch                = 'index_merge=on,index_merge_union=on,index_merge_sort_union=on,index_merge_intersection=on'

# ---------------------------------------------------------------------------
# Binary Logging (optional — enable if you need replication or point-in-time recovery)
# ---------------------------------------------------------------------------
# Uncomment the following lines to enable binary logging:
# log_bin                       = mysql-bin
# binlog_format                 = ROW
# expire_logs_days              = 7
# max_binlog_size               = 256M
# sync_binlog                   = 1

# ---------------------------------------------------------------------------
# Slow Query Log — essential for ongoing performance monitoring
# ---------------------------------------------------------------------------
slow_query_log                  = ON
slow_query_log_file             = /var/log/mysql/slow-query.log
long_query_time                 = 1
log_queries_not_using_indexes   = ON
min_examined_row_limit          = 1000

# ---------------------------------------------------------------------------
# General Settings
# ---------------------------------------------------------------------------
# Character set — match the table definitions.
character_set_server            = utf8mb4
collation_server                = utf8mb4_unicode_ci

# Maximum allowed packet size — 64MB handles large batch inserts.
max_allowed_packet              = 64M

# Interactive timeout — close idle interactive connections after 30 min.
interactive_timeout             = 1800

# Non-interactive connection timeout — close idle connections after 10 min.
wait_timeout                    = 600

# Skip name resolution for faster connections (use IPs only).
skip_name_resolve               = ON

# Performance schema — useful for diagnostics but uses ~400MB RAM.
# Disable if you need to reclaim memory; enable for troubleshooting.
performance_schema              = ON

# ---------------------------------------------------------------------------
# InnoDB Adaptive Features
# ---------------------------------------------------------------------------
# Adaptive hash index — speeds up point lookups. Keep ON for mixed workloads.
innodb_adaptive_hash_index      = ON

# Adaptive flushing — dynamically adjusts flush rate based on redo log fill.
innodb_adaptive_flushing        = ON

# CRC32 checksums — faster than default on modern CPUs with hardware support.
innodb_checksum_algorithm       = crc32

# ---------------------------------------------------------------------------
# Bulk Insert Optimization
# ---------------------------------------------------------------------------
# Bulk insert buffer for building indexes during large inserts.
bulk_insert_buffer_size         = 64M

[mysqldump]
# Allow large dumps without running out of memory.
quick
max_allowed_packet              = 64M
