# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Clear any Vite cache and build the application
RUN rm -rf node_modules/.vite dist && npm run build

# Production stage with nginx
FROM nginx:alpine

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configurations
# HTTP-only config (default fallback)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# If an SSL config was generated by setup-certs.sh, copy it too
# This file is optional — the entrypoint will pick the right one
COPY nginx.ssl.conf* /etc/nginx/templates/

# Also keep the HTTP config available for the entrypoint fallback
COPY nginx.conf /etc/nginx/templates/nginx.conf

# Copy entrypoint script
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Expose both HTTP and HTTPS ports
EXPOSE 80 443

ENTRYPOINT ["/docker-entrypoint.sh"]
